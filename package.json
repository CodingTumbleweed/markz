{
  "name": "markz",
  "version": "0.2.0-beta.1",
  "description": "A seamless WYSIWYG Markdown editor for desktop",
  "main": "dist/main/index.js",
  "author": "Usman Akram <usman.akram.se@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/CodingTumbleweed/markz#readme",
  "repository": {
    "type": "git",
